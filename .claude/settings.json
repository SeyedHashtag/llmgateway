{
	"permissions": {
		"deny": [
			"Read(**/dist/**)",
			"Read(**/.next/**)",
			"Read(**/.next-dev/**)",
			"Read(**/.content-collections/**)",
			"Read(.conductor/**)",
			"Read(.turbo/**)"
		]
	},
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
					}
				]
			}
		]
	}
}
